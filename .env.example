# Copy this file to .env and fill in your values before running docker compose.
# Only secrets that can't have safe defaults are listed here.

# OpenRouter — required for the AI agent
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free

# Exa web search — optional (agent still works without it, just no web search)
EXA_API_KEY=exa-...

# Admin dashboard credentials
ADMIN_USERNAME=admin_username
ADMIN_PASSWORD=admin_password
